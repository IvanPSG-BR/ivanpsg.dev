---
/**
 * Página Principal - Index
 *
 * Integra todos os componentes do portfólio:
 * - Header (navegação)
 * - Hero (apresentação)
 * - About (sobre mim)
 * - Projects (projetos)
 * - Contact (contato)
 * - Footer
 *
 * Nota: Carousel (certificados) removido temporariamente.
 * O componente src/components/Carousel.astro está preservado para reuso futuro.
 */

import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Base
  title="Ivan Pedro Sampaio Gonçalves — Desenvolvedor Backend Node.js"
  description="Portfólio de Ivan Pedro Sampaio Gonçalves, desenvolvedor backend em Salvador/BA. APIs e sistemas eficientes com Node.js, TypeScript, PostgreSQL e Docker — código limpo e escalável."
  ogType="profile"
  keywords={[
    "Ivan Pedro Salvador",
    "desenvolvedor backend Node.js Salvador",
    "desenvolvedor backend TypeScript Brasil",
    "programador Python PostgreSQL",
    "desenvolvedor APIs REST Fastify",
    "portfólio backend junior 2026",
    "contratar desenvolvedor backend remoto Brasil",
    "freelancer backend Node.js Bahia",
  ]}
>
  <!-- Header com navegação -->
  <Header />

  <!-- Hero - Apresentação principal -->
  <Hero />

  <!-- Sobre Mim -->
  <About />

  <!-- Projetos em destaque -->
  <Projects />

  <!-- Formulário de contato -->
  <Contact />

  <!-- Footer -->
  <Footer />
</Base>
