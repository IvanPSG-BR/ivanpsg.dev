---
/**
 * Hero Component - Seção de apresentação principal
 *
 * Efeito terminal: ao carregar a página, "whoami" é digitado no prompt
 * e o conteúdo principal (foto, nome, cargo, stack, botão) é revelado.
 */

import icons from "../json/icons.json";
import sections from "../json/sections.json";

const heroSection = sections.hero;
const stackIcons = icons.hero.stack;
const downloadIcon = icons.hero.download;

const resumePath = import.meta.env.RESUME_PATH ?? "/CURRICULO_DEV_IVAN_PEDRO.pdf"
const photoPath = import.meta.env.PRO_PHOTO_PATH ?? "/ivan_profissional.png"
---

<section
  class="section bg-modern-bg"
  id={heroSection.tagId}
  aria-labelledby={heroSection.titleId}
  data-terminal-section
>
  <div class="container-custom">
    <div class="flex flex-col items-center text-center gap-8">
      <!-- Prefixo terminal — data-terminal-command define o texto a ser digitado -->
      <p
        class="font-mono text-sm md:text-base text-modern-muted"
        data-terminal-command={heroSection.commandLabel}
      >
        <span class="text-modern-accent">ivanpsg@portifolio</span>:<span
          class="text-modern-accent2">~</span
        >$ <span class="text-modern-text"
          ><span data-terminal-text></span><span
            class="terminal-cursor"
            aria-hidden="true"></span></span
        >
      </p>

      <!-- Conteúdo revelado após a digitação do comando -->
      <div class="section-content w-full flex flex-col items-center gap-8">
        <!-- Foto do perfil + citação interativa -->
        <div
          id="photo-interactive"
          class="shrink-5 flex flex-col items-center gap-0 w-60"
        >
          <img
            id="hero-photo"
            src={photoPath}
            alt="Foto profissional de Ivan Pedro Sampaio Gonçalves, desenvolvedor backend em Salvador/BA"
            width="1840"
            height="1840"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-40 h-40 md:w-48 md:h-48 lg:w-56 lg:h-56 rounded-full border-4 border-modern-accent2 bg-modern-surface/60 object-cover transition-transform duration-300 ease-in-out"
          />

          <!-- Citação: aparece com fade-in abaixo da foto no hover/toque -->
          <div
            id="hero-quote-container"
            class="max-h-0 overflow-hidden opacity-0 transition-all duration-300 ease-in-out w-80 md:w-96"
            aria-live="polite"
            aria-atomic="true"
          >
            <blockquote class="italic text-sm text-modern-muted leading-relaxed text-center px-2 pt-3">
              <p id="hero-quote-text"></p>
            </blockquote>
          </div>
        </div>

        <!-- Conteúdo textual -->
        <div class="max-w-3xl">
          <!-- Título com nome -->
          <h1
            id={heroSection.titleId}
            class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4"
          >
            <span class="text-modern-accent">Ivan Pedro</span>
            <br />
            <span class="text-modern-accent2">Sampaio Gonçalves</span>
          </h1>

          <!-- Subtítulo com cargo -->
          <p class="text-xl md:text-2xl text-modern-muted mb-3">
            Desenvolvedor Backend
          </p>

          <!-- Frase de efeito / manifesto pessoal
          <p class="font-mono text-sm md:text-base text-modern-accent/70 mb-8 italic">
            Construindo software simples, eficiente e acessível.
          </p> 
          -->
        </div>

        <!-- Ícones de Stack (8 tecnologias) -->
        <div
          class="flex flex-wrap justify-center items-center gap-6 md:gap-8"
        >
          {
            stackIcons.map((icon) => (
              <div
                class="w-12 h-12 md:w-14 md:h-14 rounded-full border-2 border-modern-text flex items-center justify-center hover:bg-modern-accent hover:border-modern-accent transition-all duration-240 group"
                title={icon.name}
              >
                <i
                  class={`${icon.icon} text-2xl md:text-3xl text-modern-text group-hover:text-black`}
                  aria-hidden="true"
                />
              </div>
            ))
          }
        </div>

        <!-- Botão de currículo -->
        <div class="flex justify-center">
          <a
            href={resumePath}
            download
            class="btn-primary text-base md:text-lg px-8 py-4"
            aria-label="Baixar currículo em PDF"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox={downloadIcon.viewBox}
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d={downloadIcon.path}
              ></path>
            </svg>
            Baixar Currículo
          </a>
        </div>
      </div>
      <!-- /section-content -->
    </div>
  </div>
</section>

<script>
  import '../scripts/quote-engine.js';
</script>
