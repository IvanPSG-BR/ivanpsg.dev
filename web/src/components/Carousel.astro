---
/**
 * Carousel Component - Carrossel de certificados
 * 
 * Features:
 * - Navegação com setas (prev/next)
 * - Indicadores de posição (dots)
 * - Animação CSS suave
 * - Hit areas de 44px (acessibilidade)
 * - Suporte a teclado
 */

// Dados dos certificados (placeholder com 2XXX)
const certificates = [
  {
    title: 'Certificado Placeholder 1',
    issuer: 'Plataforma Online',
    date: '2XXX',
    image: '/certificates/cert1.jpg',
  },
  {
    title: 'Certificado Placeholder 2',
    issuer: 'Plataforma Online',
    date: '2XXX',
    image: '/certificates/cert2.jpg',
  },
  {
    title: 'Certificado Placeholder 3',
    issuer: 'Plataforma Online',
    date: '2XXX',
    image: '/certificates/cert3.jpg',
  },
];
---

<section 
  id="certificados"
  class="section bg-modern-surface"
  aria-labelledby="carousel-title"
>
  <div class="container-custom">
    <!-- Título da seção -->
    <div class="text-center mb-12">
      <h2 
        id="carousel-title"
        class="text-3xl md:text-4xl font-bold text-modern-text mb-4"
      >
        Certificados & <span class="text-gradient">Qualificações</span>
      </h2>
    </div>
    
    <!-- Carrossel -->
    <div 
      class="relative max-w-4xl mx-auto"
      role="region"
      aria-label="Carrossel de certificados"
      aria-live="polite"
    >
      <!-- Container dos slides -->
      <div class="overflow-hidden rounded-lg">
        <div 
          id="carousel-track"
          class="flex transition-transform duration-500 ease-in-out"
          style="transform: translateX(0)"
        >
          {certificates.map((cert, index) => (
            <div 
              class="w-full flex-shrink-0 px-4"
              data-slide={index}
              role="group"
              aria-roledescription="slide"
              aria-label={`Slide ${index + 1} de ${certificates.length}: ${cert.title}`}
            >
              <div class="bg-modern-bg border border-modern-border rounded-lg p-8 text-center">
                <!-- Ícone de certificado -->
                <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-modern-accent/10 border border-modern-accent flex items-center justify-center">
                  <svg 
                    class="w-8 h-8 text-modern-accent" 
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                    />
                  </svg>
                </div>
                
                <!-- Conteúdo -->
                <h3 class="text-2xl font-bold text-modern-text mb-2">
                  {cert.title}
                </h3>
                <p class="text-modern-muted mb-1">
                  {cert.issuer}
                </p>
                <p class="text-sm text-modern-muted font-mono">
                  {cert.date}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Setas de navegação -->
      <button
        id="carousel-prev"
        type="button"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 w-11 h-11 rounded-full bg-modern-surface border border-modern-border hover:border-modern-accent transition-all duration-240 hover:scale-110 flex items-center justify-center"
        aria-label="Certificado anterior"
      >
        <svg 
          class="w-6 h-6 text-modern-text" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="2" 
            d="M15 19l-7-7 7-7"
          />
        </svg>
      </button>
      
      <button
        id="carousel-next"
        type="button"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 w-11 h-11 rounded-full bg-modern-surface border border-modern-border hover:border-modern-accent transition-all duration-240 hover:scale-110 flex items-center justify-center"
        aria-label="Próximo certificado"
      >
        <svg 
          class="w-6 h-6 text-modern-text" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="2" 
            d="M9 5l7 7-7 7"
          />
        </svg>
      </button>
      
      <!-- Indicadores (dots) -->
      <div 
        class="flex justify-center gap-2 mt-8"
        role="tablist"
        aria-label="Navegação de slides"
      >
        {certificates.map((_, index) => (
          <button
            type="button"
            class="carousel-dot w-2.5 h-2.5 rounded-full bg-modern-border transition-all duration-240 hover:bg-modern-accent"
            data-index={index}
            role="tab"
            aria-label={`Ir para slide ${index + 1}`}
            aria-selected={index === 0 ? 'true' : 'false'}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Carrossel logic
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const dots = document.querySelectorAll('.carousel-dot');
  
  let currentIndex = 0;
  const totalSlides = dots.length;
  
  function updateCarousel() {
    if (!track) return;
    
    // Atualizar transform do track
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    
    // Atualizar dots
    dots.forEach((dot, index) => {
      if (index === currentIndex) {
        dot.classList.add('bg-modern-accent', 'w-8');
        dot.classList.remove('bg-modern-border');
        dot.setAttribute('aria-selected', 'true');
      } else {
        dot.classList.remove('bg-modern-accent', 'w-8');
        dot.classList.add('bg-modern-border');
        dot.setAttribute('aria-selected', 'false');
      }
    });
  }
  
  function goToSlide(index: number) {
    currentIndex = (index + totalSlides) % totalSlides;
    updateCarousel();
  }
  
  // Event listeners
  prevBtn?.addEventListener('click', () => {
    goToSlide(currentIndex - 1);
  });
  
  nextBtn?.addEventListener('click', () => {
    goToSlide(currentIndex + 1);
  });
  
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      goToSlide(index);
    });
  });
  
  // Suporte a teclado
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') {
      goToSlide(currentIndex - 1);
    } else if (e.key === 'ArrowRight') {
      goToSlide(currentIndex + 1);
    }
  });
  
  // Auto-play opcional (descomentarara ativar)
  // setInterval(() => {
  //   goToSlide(currentIndex + 1);
  // }, 5000);
</script>
