---
/**
 * Base Layout - Layout principal do portfólio
 *
 * Estrutura HTML semântica com:
 * - SEO completo: canonical, OG/Twitter, robots, JSON-LD (Person + WebSite)
 * - Fontes Google (Inter + JetBrains Mono)
 * - Global CSS com paleta Modern Coder
 * - Skip link para acessibilidade
 * - Suporte a tema claro/escuro
 */

import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Imagem para preview em redes sociais (caminho absoluto a partir da raiz). */
  ogImage?: string;
  /** Tipo Open Graph (website, article, profile...). */
  ogType?: "website" | "article" | "profile";
  /** Quando true, instrui motores a não indexarem (ex.: páginas de rascunho). */
  noindex?: boolean;
  /** Keywords adicionais específicas da página. */
  keywords?: string[];
}

const baseDomain = (import.meta.env.BASE_DOMAIN ?? "ivanpsg.dev")
  .replace(/^https?:\/\//, "")
  .replace(/\/$/, "");
const baseUrl = `https://${baseDomain}`;
const emailAddress = import.meta.env.EMAIL_ADDRESS ?? "";
const githubUrl = import.meta.env.GITHUB_URL ?? "";
const linkedinUrl = import.meta.env.LINKEDIN_URL ?? "";
const proPhotoPath = import.meta.env.PRO_PHOTO_PATH ?? ""
const heroEntityId = `${baseUrl}/#hero`;

const {
  title = "Ivan Pedro Sampaio Gonçalves — Desenvolvedor Backend | Portfólio",
  description = "Portfólio de Ivan Pedro Sampaio Gonçalves, desenvolvedor backend em Salvador/BA. Foco em Node.js, TypeScript, Python, PostgreSQL e arquitetura minimalista e eficiente.",
  ogImage = proPhotoPath,
  ogType = "website",
  noindex = false,
  keywords = [],
} = Astro.props;

// URL canônica absoluta baseada em `site` (configurado em astro.config.mjs)
const canonicalURL = new URL(Astro.url.pathname, baseUrl).toString();
const ogImageURL = new URL(ogImage, baseUrl).toString();

// Long-tail keywords — combina padrão + extras passadas pela página
const defaultKeywords = [
  "Ivan Pedro Sampaio Gonçalves",
  "Ivan Pedro",
  "Ivan programador",
  "Ivan desenvolvedor",
  "Ivan Pedro desenvolvedor",
  "ivanpsg",
  "desenvolvedor backend",
  "desenvolvedor backend junior",
  "desenvolvedor backend Salvador",
  "desenvolvedor backend Bahia",
  "desenvolvedor backend Brasil",
  "desenvolvedor backend remoto",
  "programador backend Salvador BA",
  "desenvolvedor Node.js",
  "desenvolvedor Node.js TypeScript",
  "desenvolvedor TypeScript",
  "desenvolvedor PostgreSQL",
  "desenvolvedor Fastify",
  "desenvolvedor NestJS",
  "desenvolvedor APIs REST",
  "desenvolvedor APIs Node.js",
  "desenvolvedor full stack iniciante",
  "portfólio desenvolvedor backend",
  "portfólio programador backend",
  "portfólio Node.js TypeScript",
  "currículo desenvolvedor backend",
  "desenvolvedor Linux",
  "desenvolvedor Docker",
  "engenheiro de software backend",
  "software minimalista",
  "código limpo backend",
  baseDomain,
];
const allKeywords = Array.from(new Set([...defaultKeywords, ...keywords])).join(", ");

// JSON-LD: Person + WebSite + ProfilePage
// Estruturado para que Google, ChatGPT, Perplexity e outros LLMs
// identifiquem entidade, autoria e relações sociais.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": heroEntityId,
  name: "Ivan Pedro Sampaio Gonçalves",
  alternateName: ["Ivan Pedro", "ivanpsg"],
  url: baseUrl,
  image: new URL(proPhotoPath, baseUrl).toString(),
  jobTitle: "Desenvolvedor Backend",
  description:
    "Desenvolvedor backend em Salvador/BA, focado em Node.js, TypeScript e PostgreSQL.",
  email: emailAddress ? `mailto:${emailAddress}` : undefined,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Salvador",
    addressRegion: "BA",
    addressCountry: "BR",
  },
  knowsAbout: [
    "Node.js",
    "TypeScript",
    "PostgreSQL",
    "Fastify",
    "NestJS",
    "Docker",
    "Linux",
    "APIs REST",
    "Arquitetura de software",
  ],
  knowsLanguage: ["pt-BR", "en"],
  sameAs: [githubUrl, linkedinUrl].filter(Boolean),
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${baseUrl}/`,
  url: baseUrl,
  name: baseDomain,
  description:
    "Portfólio profissional de Ivan Pedro Sampaio Gonçalves, desenvolvedor backend.",
  inLanguage: "pt-BR",
  author: { "@id": heroEntityId },
  publisher: { "@id": heroEntityId },
};

const profilePageLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  url: canonicalURL,
  name: title,
  description,
  inLanguage: "pt-BR",
  mainEntity: { "@id": heroEntityId },
};
---

<!doctype html>
<html lang="pt-BR" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0b0f10" />
    <meta name="color-scheme" content="dark light" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ivan Pedro Sampaio Gonçalves" />
    <meta name="keywords" content={allKeywords} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />
    <meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={baseDomain} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content="Foto profissional de Ivan Pedro Sampaio Gonçalves" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1840" />
    <meta property="og:image:height" content="1840" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Foto profissional de Ivan Pedro Sampaio Gonçalves" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Sitemap (referência explícita para crawlers) -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Preconnect para Google Fonts (performance) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- FontAwesome Icons -->
    <script src="https://kit.fontawesome.com/e9077cd72b.js" crossorigin="anonymous"></script>

    <!-- JSON-LD: dados estruturados para Google, LLMs e mecanismos de IA -->
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(profilePageLd)} />
  </head>

  <body>
    <!-- Skip to content link para screen readers -->
    <a href="/#aboutme" class="skip-to-content">
      Pular para o conteúdo principal
    </a>

    <!-- Main content wrapper -->
    <div class="min-h-screen flex flex-col">
      <!-- Slot principal - componentes serão injetados aqui -->
      <main id="main-content" class="flex-1">
        <slot />
      </main>
    </div>

    <!-- Script para gerenciar tema (dark/light) -->
    <script>
      import "../scripts/theme.js";
    </script>

    <!-- Script do efeito de digitação terminal -->
    <!-- Dispara uma vez por seção ao entrar na viewport (IntersectionObserver) -->
    <script>
      import "../scripts/terminal-typing.js";
    </script>
  </body>
</html>
